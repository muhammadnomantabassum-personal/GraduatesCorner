# Browser-safe configuration. The anon key is public by design, but every
# exposed Supabase table must have Row Level Security enabled.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_public_anon_key
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional Google Analytics 4 browser identifier. This measurement ID is
# public by design; all reporting credentials below remain server-only.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional webmaster verification values. Add the tokens supplied by each
# search engine, then redeploy before verifying domain ownership.
GOOGLE_SITE_VERIFICATION=replace_with_google_search_console_token
BING_SITE_VERIFICATION=replace_with_bing_webmaster_tools_token

# Server-only secrets. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=replace_with_server_only_service_role_key
ADMIN_SESSION_SECRET=replace_with_random_value_at_least_32_characters
ADMIN_USERNAME=replace_with_admin_identifier
ADMIN_PASSWORD_HASH=replace_with_pbkdf2_sha512_hash
CRON_SECRET=replace_with_random_cron_secret

# Optional GA4 Data API connection for the protected admin traffic dashboard.
GA4_PROPERTY_ID=replace_with_numeric_property_id
GA4_CLIENT_EMAIL=replace_with_service_account_email
GA4_PRIVATE_KEY=replace_with_service_account_private_key

# Optional external PhD feed configuration.
EXTERNAL_PHD_FEEDS=
EXTERNAL_PHD_AUTO_PUBLISH=false
